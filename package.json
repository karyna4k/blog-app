    "@nuxtjs/eslint-module": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-nuxt": "^4.0.0",
    "eslint-plugin-vue": "^9.32.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
